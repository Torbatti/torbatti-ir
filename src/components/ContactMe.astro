---
<div class="contact vbox grid jcontent-center aitems-center">
  <form action="" class="">
    <h1 class="tc4"> فرم کار نمیکند ! </h1>
    <label for="umail" class="tc1 one"> ایمیل </label>
    <input type="email" id="umail" name="umail" placeholder="">

    <label for="utext" class="tc1 one"> پیام </label>
    <textarea rows="12" cols="40" id="utext" name="utext"/>
      
    <button type="submit" class="full">ارسال</button>
  </form>
</div>

<style>
  .contact{
    height:26rem;
  }
  h1{text-align:center;}
  form{
    margin:auto;
    width:80vw;
    display: grid;
    text-align:right;
    gap:8px;
  }
  #umail{
    height:36px;
  }
  #utext{
    height:10rem;
  }
  textarea {
  resize: none;
  }
  form input,form button,form label,form textarea,h1{
    width:90%;margin:auto;
  }
  input:focus,textarea:focus
  {
    outline:0;
  }
  input,textarea,button{
    border:0;
    background:none;
    background: linear-gradient(90deg, rgba(238,240,242,1) 0%, rgba(218,218,218,1) 100%);
    border-radius: 12px;
    padding:12px;
    box-shadow: rgba(0, 0, 0, 0.19) 0px 4px 8px, rgba(0, 0, 0, 0.23) 0px 2px 2px;

  }
  button{
    background:#DA627D;
    color: aliceblue;
    font-weight:bold;
  }
  button:hover{
    background: linear-gradient(90deg, rgba(218,98,125,1) 0%, rgba(187,97,117,1) 100%);
    cursor:pointer;
  }



</style>