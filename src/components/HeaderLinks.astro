---
const {classList} = Astro.props;
---
<div class={classList}>
  <div class="links flex">
    <a href="blog">بلاگ</a>
    <a href="about">درباره</a>
    <a href="project">دستاورد</a>
    <a href="contact">تماس</a>
  </div>
</div>


<style>
  .links a{color:#EEF0F2;font-size:medium;font-weight:bold;}
  .links{flex-direction:column;align-items:center;}
  @media(max-width:768px){
    .links{gap:20px;margin-top: 6rem;}
    .links a{font-size:large;}
  }
  @media(min-width:768px){
    .links{width:24rem;flex-direction:row;gap:8px;}
    .links a{transition:transform 0.3s ease-in-out;}
    .links a:hover{transform:translate(0,-4px);}
  }
  

</style>