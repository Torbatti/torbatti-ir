---
const {classList} = Astro.props;
---
<div class={classList}>
  <div class="menu-icons box-row flex jcontent-center aitems-center">
    <a href="" target="_blank" class="gicon"><img src="github.svg" alt="github icon" width="32px" ></a>
    <a href="" target="_blank"><img src="telegram.svg" alt="telegram icon" width="32px" class="md-hide"></a>
    <a href="" target="_blank"><img src="mastodon.svg" alt="mastodon icon" width="32px" class="md-hide"></a>
  </div>
</div>

<style>
    .menu-icons{gap:16px;}
    @media(min-width:768px){
      .gicon img{
        width:24px;
        display:grid;
        justify-content:center;
        align-items:center;
      }
      a{transition:transform 0.3s ease-in-out;}
      a:hover{transform:translate(0,-4px);}
    }
</style>